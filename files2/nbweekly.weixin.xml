<guid>b7c6f8cfe1d7f8d787ea2790d5ccfe5d</guid>
<title>热搜第一！央行发公告</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E5%8D%97%E9%83%BD%E5%91%A8%E5%88%8A+%E7%83%AD%E6%90%9C%E7%AC%AC%E4%B8%80%EF%BC%81%E5%A4%AE%E8%A1%8C%E5%8F%91%E5%85%AC%E5%91%8A</link>
<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;section&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_png/V9V83VFzia0RxiaK3eOWibdaTQbp9fz5bxLDOr9LRl0nibN9wB40ATibG6h7ibntXCn3U5UfmdF9BNYJX3ECFf8QLgUg/640?wx_fmt=other&amp;amp;from=appmsg&amp;amp;wxfrom=5&amp;amp;wx_lazy=1&amp;amp;tp=webp#imgIndex=0&quot; /&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_png/V9V83VFzia0TzpazRHiaUD7qgPRVzxlbeibBdAHnT67xfibKV4l0BOR747iaKqLa4zKnLI8Vp7ymUUGm2onwZV7xiaWA/640?wx_fmt=other&amp;amp;wxfrom=5&amp;amp;wx_lazy=1&amp;amp;tp=webp#imgIndex=1&quot; /&gt;&lt;/span&gt;&lt;span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-left: 16px; margin-right: 16px; line-height: 1.6em;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; letter-spacing: normal;&quot;&gt;2月27日，中国人民银行发布公告：为促进外汇市场发展，支持企业管理好汇率风险，&lt;/span&gt;&lt;span style=&quot;font-size: 16px; letter-spacing: normal; font-weight: bold;&quot;&gt;中国人民银行决定自2026年3月2日起，将远期售汇业务的外汇风险准备金率从20%下调至0&lt;/span&gt;&lt;span style=&quot;font-size: 16px; letter-spacing: normal;&quot;&gt;。下一步，中国人民银行将继续引导金融机构优化对企业汇率避险服务，保持人民币汇率在合理均衡水平上的基本稳定。&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;text-align: center; margin-left: 16px; margin-right: 16px;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_jpg/N4IOFu6gHFatOxlmR9OOOF94KOcTmosL8HJia4pOJXfb4NsVTYMichWedlrbNUsQ2lprdLZ0fia1ftv1zlqPyF8iaaoUFUrMfGflyLtnqGvDwIs/640?wx_fmt=jpeg&amp;amp;from=appmsg&quot; type=&quot;block&quot; /&gt;&lt;/section&gt;&lt;section style=&quot;margin-left: 16px; margin-right: 16px; line-height: 1.6em;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; letter-spacing: normal;&quot;&gt;此消息发布后，迅速登上微博热搜第一。&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-left: 16px; margin-right: 16px; line-height: 1.6em;&quot;&gt;&lt;span style=&quot;font-size: 16px; letter-spacing: normal;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_png/N4IOFu6gHFax4JE8GRQmoTlS4bf8ntbNPBJP2B5dSEDLImeyXsQNdtSmY5pxfwgn9pfm6a5sSQwPOHxcxRAsicYhtC6sY97Iv1hvf3TdY8JM/640?wx_fmt=png&amp;amp;from=appmsg&quot; type=&quot;block&quot; /&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;section style=&quot;margin-left: 16px; margin-right: 16px; line-height: 1.6em;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-left: 16px; margin-right: 16px; line-height: 1.6em;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 15px; letter-spacing: normal; font-weight: bold;&quot;&gt;来源：南都湾财社综合自央视新闻、新浪微博&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span&gt;END&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section&gt;&lt;section class=&quot;mp_profile_iframe_wrp&quot;&gt;&lt;/section&gt;&lt;/section&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img __bg_gif&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_gif/V9V83VFzia0QoMAF1picfl3Dx0L3tDgDUOEKVsplMv3ibS0UdicD7qufPp4MMOjaePPiaT5Ex8o6YZnUuxchf5XAiaug/640?wx_fmt=gif&amp;amp;wxfrom=5&amp;amp;wx_lazy=1&amp;amp;tp=webp#imgIndex=5&quot; /&gt;&lt;/section&gt;&lt;section style=&quot;margin-left: 16px; margin-right: 16px; line-height: 1.6em;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;p style=&quot;display: none;&quot;&gt;&lt;/p&gt;&lt;/div&gt;
    

    
