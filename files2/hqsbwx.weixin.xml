<title>特朗普：已构成“危及国家安全的紧急状态”</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E7%89%B9%E6%9C%97%E6%99%AE%EF%BC%9A%E5%B7%B2%E6%9E%84%E6%88%90%E2%80%9C%E5%8D%B1%E5%8F%8A%E5%9B%BD%E5%AE%B6%E5%AE%89%E5%85%A8%E7%9A%84%E7%B4%A7%E6%80%A5%E7%8A%B6%E6%80%81%E2%80%9D</link>
<content:encoded>&lt;div&gt;&lt;div&gt;fff
    
