gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section style=&quot;font-size: 14px; color: rgb(124, 125, 126); line-height: 1.75;&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;来源 | 新华社&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;section style=&quot;font-size: 14px; color: rgb(124, 125, 126); line-height: 1.75;&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;审核 | 李剑&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;编辑 | 徐铉&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;b&gt;&lt;span&gt;校对 | 郭炜桐&lt;/span&gt;&lt;/b&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;text-align: left; display: flex;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 46%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dotted rgb(18, 39, 54);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 8%;&quot;&gt;&lt;section style=&quot;text-align: center; margin: 8px 0% 10px; line-height: 0;&quot;&gt;&lt;section style=&quot;vertical-align: middle; display: inline-block; line-height: 0;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_gif/z8icaWS616QV8nDXb3h1HbJ2v9KIH3TVe4A1DF40b2XFrzBWP28MoqdRra1ibkBACe4