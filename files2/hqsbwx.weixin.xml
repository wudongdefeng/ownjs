<title>国家矿山安全监察局山西局党组书记、局长胡海军被查</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E5%9B%BD%E5%AE%B6%E7%9F%BF%E5%B1%B1%E5%AE%89%E5%85%A8%E7%9B%91%E5%AF%9F%E5%B1%80%E5%B1%B1%E8%A5%BF%E5%B1%80%E5%85%9A%E7%BB%84%E4%B9%A6%E8%AE%B0%E3%80%81%E5%B1%80%E9%95%BF%E8%83%A1%E6%B5%B7%E5%86%9B%E8%A2%AB%E6%9F%A5</link>
