<title>伊朗宣布：全国哀悼40天</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E4%BC%8A%E6%9C%97%E5%AE%A3%E5%B8%83%EF%BC%9A%E5%85%A8%E5%9B%BD%E5%93%80%E6%82%BC40%E5%A4%A9</link>
