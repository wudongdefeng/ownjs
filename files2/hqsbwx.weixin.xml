<title>美军行动大量运用人工智能，国防部回应！</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E7%BE%8E%E5%86%9B%E8%A1%8C%E5%8A%A8%E5%A4%A7%E9%87%8F%E8%BF%90%E7%94%A8%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%EF%BC%8C%E5%9B%BD%E9%98%B2%E9%83%A8%E5%9B%9E%E5%BA%94%EF%BC%81</link>
