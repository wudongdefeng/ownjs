on&gt;&lt;/section&gt;&lt;p style=&quot;line-height: 1.75em; margin: 0px 8px;&quot;&gt;&lt;span style=&quot;letter-spacing: 1px; font-size: 16px;&quot;&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;display: none;&quot;&gt;&lt;/p&gt;&lt;/div&gt; 
                &lt;video controls=&quot;controls&quot; id=&quot;video&quot; src=&quot;http://mpvideo.qpic.cn/0b2eembaaaaczyadqj4k2buvei6daarqeaaa.f10002.mp4?dis_k=da0a9d8026d2119d9dc0d5c7ed1b081a&amp;amp;dis_t=1770544189&amp;amp;play_scene=10120&amp;amp;auth_info=fKjU+/UMNmk5uP2JmFhbVG9VLDY1TkA0NxM2M2JMMTYQYhMAJWkVU0d/IWNWNhxGZVsrZG0bU1xKRipqPhFqK0F+GQ==&amp;amp;auth_key=37286b6957fa0a1a91677f9435bcac51&quot; width=&quot;100%&quot;&gt;
