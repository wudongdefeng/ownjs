<title>古巴：感谢中国</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E5%8F%A4%E5%B7%B4%EF%BC%9A%E6%84%9F%E8%B0%A2%E4%B8%AD%E5%9B%BD</link>
