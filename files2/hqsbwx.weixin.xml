<title>拉赫蒙抵达北京</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E6%8B%89%E8%B5%AB%E8%92%99%E6%8A%B5%E8%BE%BE%E5%8C%97%E4%BA%AC</link>
