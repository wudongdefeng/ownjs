gt;&lt;span&gt;长按下方二维码关注我们or回到文章顶部，点击环球时报 （微信公众号ID：hqsbwx）&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;margin: 0px 0%; display: flex;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; width: 33.33%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;background-color: rgb(160, 160, 160); height: 1px;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; width: 33.33%;&quot;&gt;&lt;section style=&quot;margin: 0px 0%; line-height: 0;&quot;&gt;&lt;section style=&quot;vertical-align: middle; display: inline-block; line-height: 0; width: 100%;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_jpg/z8icaWS616QWNWHjiahTFho1LgpcsBvicktmQ7iapCXrAwkrtUFF7oOUiagsSVaHZ0hYR4ibtPCjVTwdCzEmwSCuUwB1RkpZ47NwO2Ob1A1AyBgDc/640?wx_fmt=jpeg&amp;amp;from=appmsg&quot; style=&quot;vertical-align: middle; width: 100%;&quot; /&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; width: 33.33%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;background-color: rgb(160, 160, 160); height: 1px;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;p style=&quot;display: none;&quot;&gt;&lt;/p&gt;&lt;/div&gt;
    

    
