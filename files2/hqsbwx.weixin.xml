<title>美国将对中国等16个贸易伙伴发起301调查，中方回应</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E7%BE%8E%E5%9B%BD%E5%B0%86%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%AD%8916%E4%B8%AA%E8%B4%B8%E6%98%93%E4%BC%99%E4%BC%B4%E5%8F%91%E8%B5%B7301%E8%B0%83%E6%9F%A5%EF%BC%8C%E4%B8%AD%E6%96%B9%E5%9B%9E%E5%BA%94</link>
