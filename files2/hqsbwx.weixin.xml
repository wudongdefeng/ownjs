<title>中国工程院撤销张尧学院士称号</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E4%B8%AD%E5%9B%BD%E5%B7%A5%E7%A8%8B%E9%99%A2%E6%92%A4%E9%94%80%E5%BC%A0%E5%B0%A7%E5%AD%A6%E9%99%A2%E5%A3%AB%E7%A7%B0%E5%8F%B7</link>
