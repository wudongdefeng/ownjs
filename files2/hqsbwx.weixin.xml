: 8%;&quot;&gt;&lt;section style=&quot;text-align: center; margin: 8px 0% 10px; line-height: 0;&quot;&gt;&lt;section style=&quot;vertical-align: middle; display: inline-block; line-height: 0;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_gif/z8icaWS616QWZ1WWdhicqdq7bYGZtGiaibe3kD9FY2u3kPRPe2QnMLGAcMs5HMPCNnicvwT52ST66kXRqWyOibjibcYS29HGwNZ8482o2xFtVbeCLo/640?wx_fmt=gif&amp;amp;from=appmsg&quot; style=&quot;vertical-align: middle; width: 100%;&quot; /&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 46%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dotted rgb(18, 39, 54);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section&gt;&lt;section&gt;&lt;section style=&quot;display: inline-block; width: 90%; vertical-align: top;&quot;&gt;&lt;section style=&quot;margin: 15px 0%;&quot;&gt;&lt;section style=&quot;font-size: 16px; color: rgb(170, 38, 17); letter-spacing: 2px; line-height: 1;&quot;&gt;&lt;p style=&quot;margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dashed rgb(42, 42, 42);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;margin: 0px 0% 10px;&quot;&gt;&lt;section style=&quot;font-size: 12px; text-align: justify; letter-spacing: 1px; line-height: 1.2; color: rgb(126, 123, 122);&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;span&gt;请&lt;/span&gt;&lt;/span&gt;&lt;span&gt;长按下方二维码关注我们or回到文章顶部，点击环球时报 （微信公众号ID：hqs