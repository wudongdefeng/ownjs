<title>特朗普威胁：下一个就是古巴</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E7%89%B9%E6%9C%97%E6%99%AE%E5%A8%81%E8%83%81%EF%BC%9A%E4%B8%8B%E4%B8%80%E4%B8%AA%E5%B0%B1%E6%98%AF%E5%8F%A4%E5%B7%B4</link>
<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;section style=&quot;margin: 0px; padding-left: 15px;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 100%;&quot;&gt;&lt;section&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;border-left: 1px solid rgb(170, 38, 17); height: 1.2em; border-top-color: rgb(170, 38, 17); border-right-color: rgb(170, 38, 17); border-bottom-color: rgb(170, 38, 17);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section&gt;&lt;section style=&quot;width: 0px; margin-left: 5px; border-right: 10px solid rgb(170, 38, 17); display: inline-block; margin-top: 1.7em; vertical-align: top; border-top: 6px solid transparent !important; border-bottom: 6px solid transparent !important;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; background-color: rgb(170, 38, 17); width: 90%; padding: 8px; margin: 0.5em auto; border-radius: 8px;&quot;&gt;&lt;section style=&quot;color: rgb(255, 255, 255);&quot;&gt;&lt;p style=&quot;clear: none; white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;美国总统特朗普当地时间3月5日下午称，他希望先结束伊朗战争，之后“古巴只是时间问题”。&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section style=&quot;text-align: justify; letter-spacing: 0.578px; margin: 0px; line-height: 2; text-indent: 0px; font-size: 17px;&quot;&gt;&lt;span styl