<title>猝死前1小时，身体会发出预警，千万别忽视！</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E7%8C%9D%E6%AD%BB%E5%89%8D1%E5%B0%8F%E6%97%B6%EF%BC%8C%E8%BA%AB%E4%BD%93%E4%BC%9A%E5%8F%91%E5%87%BA%E9%A2%84%E8%AD%A6%EF%BC%8C%E5%8D%83%E4%B8%87%E5%88%AB%E5%BF%BD%E8%A7%86%EF%BC%81</link>
<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;p style=&quot;margin-bottom: 8px; letter-spacing: 0.578px; text-align: center; line-height: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;心源性猝死&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin-bottom: 8px; letter-spacing: 0.578px; text-align: center; line-height: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 16px; font-family: mp-quote, ;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;肺源性猝死、脑源性猝死&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin-bottom: 8px; letter-spacing: 0.578px; text-align: center; line-height: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 16px; font-family: mp-quote, ;&quot;&gt;&lt;span style=&quot;letter-spacing: 0.578px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;是&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;letter-spacing: 0.578px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;猝死发生的主要原&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;letter-spacing: 0.578px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;因&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center; line-height: 1.75em; margin-bottom: 8px;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;letter-spacing: 0.578px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;许多人以为&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center; line-height: 1.75em; margin-bottom: 8px;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;letter-spacing: 0.578px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;猝死总是突然发生&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center; line-height: 1.75em; margin-bottom: 8px;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;letter-spacing: 0.578px;&quot;&gt;&lt;span&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;其实，身体早已向我们&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;letter-spacing: 0.544px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;释放了信号&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center; line-height: 1.75em; margin-bottom: 8px;&quot;&gt;&lt;span style=&quot;font-size: 16px; letter-spacing: 0.544px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;哪些症状是身体在警告我们？&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center; line-height: 1.75em; margin-bottom: 16px;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;我们该如何自救？&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;section style=&quot;text-align: center; margin-bottom: 0px; line-height: 1.75em;&quot;&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img js_insertlocalimg&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_png/oq1PymRl9D4CCbIEuA3m2vtZsJ9ssLY9VJI89NeF1xNUeHyLuqUIsyKsEUP53q3ia2rEEOnfs0iaap35Jb8Z0qqg/640?wx_fmt=png&amp;amp;from=appmsg&amp;amp;wxfrom=13&amp;amp;tp=wxpic#imgIndex=1&quot; style=&quot;width: 578px !important; height: auto !important;&quot; /&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 0px; line-height: 1.75em; text-align: center;&quot;&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_png/sm80ic7WAFYibmOyCahTcqSXn0gHP6uCc7ias1gG5MhlVcQpzpdR1IQDbK2Q6ibXLMIKpoutWaBdpPg8Dv9ZJGBiaFA/640?wx_fmt=png&amp;amp;from=appmsg&amp;amp;tp=wxpic&amp;amp;wxfrom=5&amp;amp;wx_lazy=1&amp;amp;wx_co=1#imgIndex=2&quot; style=&quot;width: 578px !important; height: auto !important;&quot; /&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 0px; line-height: 1.75em; text-align: center;&quot;&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_png/sm80ic7WAFYibmOyCahTcqSXn0gHP6uCc7TRkb3demia2ayZaEeFib4sScNkrkULkp10Tian0ds9Aib9lickmzMbmnAqg/640?wx_fmt=png&amp;amp;from=appmsg&amp;amp;tp=wxpic&amp;amp;wxfrom=5&amp;amp;wx_lazy=1&amp;amp;wx_co=1#imgIndex=3&quot; style=&quot;width: 578px !important; height: auto !important;&quot; /&gt;&lt;/section&gt;&lt;section style=&quot;text-align: center; margin-bottom: 0px; line-height: 1.75em;&quot;&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img js_insertlocalimg&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_png/oq1PymRl9D4CCbIEuA3m2vtZsJ9ssLY96XqnvA6jhztjncwp1okdZ5FkWia3dKCKOwogLMfrebmMQlZGHOvRfOw/640?wx_fmt=png&amp;amp;from=appmsg&amp;amp;tp=wxpic&amp;amp;wxfrom=5&amp;amp;wx_lazy=1#imgIndex=4&quot; style=&quot;width: 578px !important; height: auto !important;&quot; /&gt;&lt;/section&gt;&lt;section style=&quot;text-align: center; margin-bottom: 0px; line-height: 1.75em;&quot;&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img js_insertlocalimg&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_png/oq1PymRl9D4CCbIEuA3m2vtZsJ9ssLY9oaiaGXPRBeic5csdpgByuMmibwgJPHCPyX7nKtyBTyRz7vWQySJpAiceOg/640?wx_fmt=png&amp;amp;from=appmsg&amp;amp;tp=wxpic&amp;amp;wxfrom=5&amp;amp;wx_lazy=1#imgIndex=5&quot; style=&quot;width: 578px !important; height: auto !important;&quot; /&gt;&lt;/section&gt;&lt;section style=&quot;text-align: center; margin-bottom: 0px; line-height: 1.75em;&quot;&gt;&lt;img alt=&quot;图片