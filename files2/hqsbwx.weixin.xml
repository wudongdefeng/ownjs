<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E9%A6%96%E6%AC%A1%EF%BC%81%E4%BC%8A%E5%AA%92%E5%85%AC%E5%B8%83%E6%89%A3%E6%8A%BC%E9%9B%86%E8%A3%85%E7%AE%B1%E8%88%B9%E7%94%BB%E9%9D%A2</link>
<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;section style=&quot;margin: 0px; padding-left: 15px;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 100%;&quot;&gt;&lt;section&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;border-left: 1px solid rgb(170, 38, 17); height: 1.2em; border-top-color: rgb(170, 38, 17); border-right-color: rgb(170, 38, 17); border-bottom-color: rgb(170, 38, 17);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section&gt;&lt;section style=&quot;width: 0px; margin-left: 5px; border-right: 10px solid rgb(170, 38, 17); display: inline-block; margin-top: 1.7em; vertical-align: top; border-top: 6px solid transparent !important; border-bottom: 6px solid transparent !important;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; background-color: rgb(170, 38, 17); width: 90%; padding: 8px; margin: 0.5em auto; border-radius: 8px;&quot;&gt;&lt;section style=&quot;color: rgb(255, 255, 255);&quot;&gt;&lt;p style=&quot;clear: none; white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;伊朗媒体首次发布画面：伊朗伊斯兰革命卫队海军扣押集装箱船。&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section class=&quot;channels_iframe_wrp&quot;&gt;&lt;/section&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;伊朗媒体23日首次发布伊朗伊斯兰革命卫队海军在霍尔木兹海峡扣押集装箱船的画面，以此回应美国总统特朗普此前多次声称的伊朗已不再拥有海军。&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;据伊媒22日报道，革命卫队称，扣押了两艘企图在没有获得授权的情况下通过霍尔木兹海峡的船只。&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;革命卫队说，这两艘船只中有一艘与以色列有关联，另一艘因未持有必要许可等原因而被认为危及海上安全。两艘船只已被革命卫队海军扣押并引导至伊朗海岸。&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;革命卫队海军重申，霍尔木兹海峡的秩序与安全是“我们的红线”。&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section style=&quot;font-size: 14px; color: rgb(124, 125, 126); line-height: 1.75;&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;来源 | 新华社&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;审核 | 卢长银&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;编辑 | 王晓娇&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;校对 | 郭炜桐&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/section&gt;&lt;section style=&quot;text-align: left; display: flex;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 46%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dotted rgb(18, 39, 54);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 8%;&quot;&gt;&lt;section style=&quot;text-align: center; margin: 8px 0% 10px; line-height: 0;&quot;&gt;&lt;section style=&quot;vertical-align: middle; display: inline-block; line-height: 0;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_gif/z8icaWS616QUEQH3FDjd6FYAtQEEfNCAHTebGhOGHXUOMGf68npL8JuQCia0XibPLsKMXWvibCD1HlCj0ibOKH7RAZ4wgY3YeAYX8QcanqpRYRpU/640?wx_fmt=gif&amp;amp;from=appmsg&quot; style=&quot;vertical-align: middle; width: 100%;&quot; /&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 46%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dotted rgb(18, 39, 54);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section&gt;&lt;section&gt;&lt;section style=&quot;display: inline-block; width: 90%; vertical-align: top;&quot;&gt;&lt;section style=&quot;margin: 15px 0%;&quot;&gt;&lt;section style=&quot;font-size: 16px; color: rgb(170, 38, 17); letter-spacing: 2px; line-height: 1;&quot;&gt;&lt;p style=&quot;margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dashed rgb(42, 42, 42);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;margin: 0px 0% 10px;&quot;&gt;&lt;section style=&quot;font-size: 12px; text-align: justify; letter-spacing: 1px; line-height: 1.2; color: rgb(126, 123, 122);&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;span&gt;请&lt;/span&gt;&lt;/span&gt;&lt;span&gt;长按下方二维码关注我们or回到文章顶部，点击环球时报 （微信公众号ID：hqsbwx）&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;margin: 0px 0%; display: flex;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; width: 33.33%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;background-color: rgb(160, 160, 160); height: 1px;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; width: 33.33%;&quot;&gt;&lt;section style=&quot;margin: 0px 0%; line-height: 0;&quot;&gt;&lt;section style=&quot;vertical-align: middle; display: inline-block; line-height: 0; width: 100%;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_jpg/z8icaWS616QWmg7lOGmsmhiaWjzOX3pydaiaaJicmq0jQGW1xzyG2u7RQzUXd1TC5Wmibut7sv8xs6xpWHia8PXiclDJ3WbJzJ04PHX8TcSL4Cr0C8/640?wx_fmt=jpeg&amp;amp;from=appmsg&quot; style=&quot;vertical-align: middle; width: 100%;&quot; /&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; width: 33.33%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;background-color: rgb(160, 160, 160); height: 1px;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;p style=&quot;display: none;&quot;&gt;&lt;/p&gt;&lt;/div&gt;
    

    
