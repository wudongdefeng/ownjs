<title>美军：三架战机遭科威特击落</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E7%BE%8E%E5%86%9B%EF%BC%9A%E4%B8%89%E6%9E%B6%E6%88%98%E6%9C%BA%E9%81%AD%E7%A7%91%E5%A8%81%E7%89%B9%E5%87%BB%E8%90%BD</link>
