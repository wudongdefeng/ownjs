<title>武契奇将访华</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E6%AD%A6%E5%A5%91%E5%A5%87%E5%B0%86%E8%AE%BF%E5%8D%8E</link>
