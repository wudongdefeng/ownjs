ign: middle; width: 33.33%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;background-color: rgb(160, 160, 160); height: 1px;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; width: 33.33%;&quot;&gt;&lt;section style=&quot;margin: 0px 0%; line-height: 0;&quot;&gt;&lt;section style=&quot;vertical-align: middle; display: inline-block; width: 100%;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img js_img_placeholder wx_img_placeholder&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_jpg/z8icaWS616QXP9VEYPzLVtNFUyW9HYP08wQJ36yak8lQNjn0Mupdiaib76HXmy9AqicZ3xfhIHZaUiam6T21Y1zcEBKoknwFO8LaObI3MxPuzKUc/640?wx_fmt=jpeg&amp;amp;from=appmsg#imgIndex=1&quot; style=&quot;vertical-align: middle; width: 100%;&quot; /&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; width: 33.33%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;background-color: rgb(160, 160, 160); height: 1px;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;p style=&quot;display: none;&quot;&gt;&lt;/p&gt;&lt;/div&gt;
    

    
