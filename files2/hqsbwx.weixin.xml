<title>痛心！逃犯开枪拒捕，37岁民警壮烈牺牲</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E7%97%9B%E5%BF%83%EF%BC%81%E9%80%83%E7%8A%AF%E5%BC%80%E6%9E%AA%E6%8B%92%E6%8D%95%EF%BC%8C37%E5%B2%81%E6%B0%91%E8%AD%A6%E5%A3%AE%E7%83%88%E7%89%BA%E7%89%B2</link>
<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;3月15日&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;四川省阿坝州公安局发布警情通报&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;红原县公安局&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;在抓捕命案逃犯索某某某&lt;span style=&quot;color: rgb(136, 136, 136);&quot;&gt;（男，53岁）&lt;/span&gt;时&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;其&lt;/span&gt;&lt;span&gt;开枪拒捕&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;致民警&lt;span style=&quot;font-weight: bold;&quot;&gt;额旺格拉&lt;/span&gt;壮烈牺牲&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span&gt;另有一名民警受伤（无生命危险）&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;在警方全力追缉和围捕下&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;犯罪嫌疑人索某某某&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;与帮助其逃跑的犯罪嫌疑人尼某某某&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;color: rgb(136, 136, 136);&quot;&gt;（男，59岁，索某某某兄长）&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-weight: bold;&quot;&gt;畏罪自杀，涉案枪支和弹药已全部缴获&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section&gt;&lt;img class=&quot;rich_pages wxw-img js_insertlocalimg&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_jpg/JPu5lvAD1XHc6jewUUqcKeGlO2Cm4JEib0zpqwulmmttO1bHgcYKpvqPEnONXhs3MiaT82EA61ewjs63O9uxMphfLeYAIGgAhoXlapJ3AUR9k/640?wx_fmt=jpeg&amp;amp;from=appmsg&quot; type=&quot;block&quot; /&gt;&lt;/section&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;额旺格拉&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;2012年毕业于&lt;/span&gt;&lt;span&gt;四川师范大学音乐学专业&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;他毅然回到高原&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;成为阿坝县阿坝镇大学生村官&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;他顶刺骨寒风、冒骄阳烈日&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;走村入户、服务群众&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;与当地群众结下深厚情谊&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;2014年10月&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;额旺格拉&lt;/span&gt;&lt;span&gt;通过招录考试进入公安队伍&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-weight: bold;&quot;&gt;从警12年，额旺格拉长期驻守在&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-weight: bold;&quot;&gt;平均海拔3500米以上的高原&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;他冲锋在前、英勇善战&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;多次参与抢险救援任务&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;和重大案件侦查抓捕工作&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section&gt;&lt;img class=&quot;rich_pages wxw-img js_insertlocalimg&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_jpg/JPu5lvAD1XHfyJnI436soKNJyPPcNP8B7TktgyApndFWZf4tfOoyhjk4sSI67zbwVJxWYE0JmibuUiaUXHa4SHVyiaT9tDp3QiaRsaWmAvke8Rk/640?wx_fmt=jpeg&amp;amp;from=appmsg&quot; type=&quot;block&quot; /&gt;&lt;/section&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;本次抓捕任务&lt;/span&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;额旺格拉&lt;/span&gt;&lt;span&gt;主动请缨参与&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;壮烈牺牲在这片养育他的草原上&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;生命永远定格在37岁&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section&gt;&lt;img class=&quot;rich_pages wxw-img js_insertlocalimg&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_jpg/JPu5lvAD1XEBILSNggI9ZNRhLt2jQmVO2KI2oaoMLITbdbGljAh3eU1h9zegweTSaO3EeFayiaxtgr5yZiaTz7EVPKNfdU1iaTJTpKzxq5PG6w/640?wx_fmt=jpeg&amp;amp;from=appmsg&quot; type=&quot;block&quot; /&gt;&lt;/section&gt;&lt;p&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;额旺格拉&lt;/span&gt;&lt;span&gt;用生命&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;践行了人民警察的铮铮誓言&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; font-weight: bold;&quot;&gt;&lt;span&gt;送别英雄，一路走好！&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;section style=&quot;font-size: 14px; color: rgb(124, 125, 126); line-height: 1.75;&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;来源 | 央视新闻&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;审核 | 李剑&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;编辑 | 王晓娇&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;校对 | 于泽淼&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/section&gt;&lt;section style=&quot;text-align: left; display: flex;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 46%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dotted rgb(18, 39, 54);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quo