<title>中方禁止Manus两高管离境？外交部回应</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E4%B8%AD%E6%96%B9%E7%A6%81%E6%AD%A2Manus%E4%B8%A4%E9%AB%98%E7%AE%A1%E7%A6%BB%E5%A2%83%EF%BC%9F%E5%A4%96%E4%BA%A4%E9%83%A8%E5%9B%9E%E5%BA%94</link>
