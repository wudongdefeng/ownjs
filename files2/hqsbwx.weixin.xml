<title>法国出动“戴高乐”号航母</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E6%B3%95%E5%9B%BD%E5%87%BA%E5%8A%A8%E2%80%9C%E6%88%B4%E9%AB%98%E4%B9%90%E2%80%9D%E5%8F%B7%E8%88%AA%E6%AF%8D</link>
<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;section style=&quot;margin: 0px; padding-left: 15px;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 100%;&quot;&gt;&lt;section&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;border-left: 1px solid rgb(170, 38, 17); height: 1.2em; border-top-color: rgb(170, 38, 17); border-right-color: rgb(170, 38, 17); border-bottom-color: rgb(170, 38, 17);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section&gt;&lt;section style=&quot;width: 0px; margin-left: 5px; border-right: 10px solid rgb(170, 38, 17); display: inline-block; margin-top: 1.7em; vertical-align: top; border-top: 6px solid transparent !important; border-bottom: 6px solid transparent !important;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; background-color: rgb(170, 38, 17); width: 90%; padding: 8px; margin: 0.5em auto; border-radius: 8px;&quot;&gt;&lt;section style=&quot;color: rgb(255, 255, 255);&quot;&gt;&lt;p style=&quot;clear: none; white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;据法国媒体6日报道，法国“戴高乐”号航空母舰进入地中海。&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;据法国RTL电台报道，“戴高乐”号航母当天下午经直布罗陀海峡进入地中海，但尚未抵达目的地。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;法国总统马克龙3日就中东局势发表电视讲话时宣布，“戴高乐”号航母已被派往地中海，随行的还有其空中力量和护卫舰。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;据法媒报道，“戴高乐”号航母此前被部署在北大西洋。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;section style=&quot;font-size: 14px; color: rgb(124, 125, 126); line-height: 1.75;&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;来源 | 新华社&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;审核 | 卢长银&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;编辑 | 王晓娇&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;校对 | 于泽淼&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/section&gt;&lt;section style=&quot;text-align: left; display: flex;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 46%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dotted rgb(18, 39, 54);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 8%;&quot;&gt;&lt;section style=&quot;text-align: center; margin: 8px 0% 10px; line-height: 0;&quot;&gt;&lt;section style