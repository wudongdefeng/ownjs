<title>徐某，取消公务员录用！</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E5%BE%90%E6%9F%90%EF%BC%8C%E5%8F%96%E6%B6%88%E5%85%AC%E5%8A%A1%E5%91%98%E5%BD%95%E7%94%A8%EF%BC%81</link>
<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;“热心群众”自称发现间谍&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;真相却是“自导自演”&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;刚考上公务员的&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;退役军人徐某&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;为获取经济利益竟主动泄密&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;……&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;国家安全部最新披露↓&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_jpg/XvpojIRrhdvmycubuBgZvtMibb7dUyTzaFKCUlW45bLxn8ibadut4jlDxdLl53znw7ww9ujzK9XbGUibI3Onu9mkgGYDicIU9RbHZhB3ickiawJEY/640?wx_fmt=jpeg&amp;amp;from=appmsg&amp;amp;tp=wxpic&amp;amp;wxfrom=5&amp;amp;wx_lazy=1#imgIndex=1&quot; type=&quot;block&quot; /&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;退役军人徐某&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;曾在部队服役5年&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;退伍后顺利通过公务员招录考试&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;进入试用期&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;但投资失败的他&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;在经济压力的驱使下&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;竟然主动联系境外间谍情报机关&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;将其部队服役期间私自留存的资料&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;逐页拍摄后&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;发送给境外间谍情报机关人员&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;以换取非法利益&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;一次交易中&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;徐某不慎泄露个人信息&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;为掩盖违法行为&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;他主动拨打&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;12339国家安全机关举报受理电话&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;伪装成热心群众&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;谎称自己发现境外间谍账号&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;与境外间谍进行了“周旋”&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;并提供了删减后的聊天记录&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;企图逃避法律制裁&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_jpg/YRrY7ghwQMoVdnhT4T48L5FjTKyiaxKicQibMbicIMRkfEwTRnutWOnGfdYHtdpTHB3nO3B746IJicY191d6XiaqCkMKtic68ViclrDu1rdf6dC42bQ/640?wx_fmt=jpeg&amp;amp;wxfrom=5&amp;amp;wx_lazy=1&amp;amp;tp=wxpic#imgIndex=1&quot; type=&quot;block&quot; /&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;办案人员很快发现&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;徐某的描述前后不一&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;经深入调查&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;国家安全机关掌握了&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;徐某主动投靠境外情报部门的&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;完整证据链&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;徐某所谓的“举报”&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;实为自导自演的一场骗局&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_jpg/YRrY7ghwQMqxSBCjxUH2DHa6CopavvibzS7lPZRgo2AQbdONOsFiamYuRSulcniaQ0xn4MfKomtq1agJCGrX4ot3EASwkRl3EFK6a77tEBcLkY/640?wx_fmt=jpeg&amp;amp;wxfrom=5&amp;amp;wx_lazy=1&amp;amp;tp=wxpic#imgIndex=2&quot; type=&quot;block&quot; /&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;徐某的行为已触犯&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;《中华人民共和国反间谍法》&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;最终&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;徐某被处行政拘留五日&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;并在公务员试用期期间&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; color: rgb(171, 25, 66); font-weight: bold;&quot;&gt;被取消录用&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section style=&quot;font-size: 14px; color: rgb(124, 125, 126); line-height: 1.75;&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;来源 | 人民网微信综合国家安全部&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;审核 | 卢长银&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;编辑 | 王晓娇&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;校对 | 郝珺石&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/section&gt;&lt;section style=&quot;text-align: left; display: flex;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 46%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dotted rgb(18, 39, 54);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 8%;&quot;&gt;&lt;section style=&quot;text-align: center; margin: 8px 0% 10px; line-height: 0;&quot;&gt;&lt;section style=&quot;vertical-align: middle; display: inline-block; line-height: 0;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/sz_mmbiz_gif/z8icaWS616QWlWGWI6J9WVgCemmV2E1icMvicibusKDvdH22CEKCsawMRkv3ervOJhnG8XaeR2c42Yc7Sjn6mV2lvCckJv4eiacKbTTNkcS2oguI/640?wx_fmt=gif&amp;amp;from=appmsg&quot; style=&quot;vertical-align: middle; width: 100%;&quot; /&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 46%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dotted rgb(18, 39, 54);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section&gt;&lt;section&gt;&lt;section style=&quot;display: inline-block; width: 90%; vertical-align: top;&quot;&gt;&lt;section style=&quot;margin: 15px 0%;&quot;&gt;&lt;section style=&quot;font-size: 16px; color: rgb(170, 38, 17); letter-spacing: 2px; line-height: 1;&quot;&gt;&lt;p style=&quot;margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt