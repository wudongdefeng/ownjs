<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;section style=&quot;margin-bottom: 8px; text-align: center;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;腾讯今天（22日）发布消息&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 8px; text-align: center;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; font-weight: bold;&quot;&gt;微信正式推出微信“ClawBot”插件&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 8px; text-align: center;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; font-weight: bold;&quot;&gt;支持接入OpenClaw&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 8px; text-align: center;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;用户扫码或复制命令&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 8px; text-align: center;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;即可将OpenClaw接入微信&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 8px; text-align: center;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;连接后&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 8px; text-align: center;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;用户就能&lt;/span&gt;&lt;span style=&quot;font-size: 16px; font-weight: bold;&quot;&gt;通过微信聊天的方式&lt;/span&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;margin-bottom: 16px; text-align: center;&quot;&gt;&lt;span&gt;&lt;span style=&quot;font-size: 16px; font-weight: bold;&quot;&gt;快速调用自己的“龙虾”&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/section&gt;&lt;section style=&quot;text-align: center;&quot;&gt;&lt;img alt=&quot;图片&quot; class=&quot;r