<title>美方宣称允许中国购买委内瑞拉石油，中方回应</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E7%BE%8E%E6%96%B9%E5%AE%A3%E7%A7%B0%E5%85%81%E8%AE%B8%E4%B8%AD%E5%9B%BD%E8%B4%AD%E4%B9%B0%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E7%9F%B3%E6%B2%B9%EF%BC%8C%E4%B8%AD%E6%96%B9%E5%9B%9E%E5%BA%94</link>
<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;section style=&quot;margin: 0px; padding-left: 15px;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 100%;&quot;&gt;&lt;section&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;border-left: 1px solid rgb(170, 38, 17); height: 1.2em; border-top-color: rgb(170, 38, 17); border-right-color: rgb(170, 38, 17); border-bottom-color: rgb(170, 38, 17);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section&gt;&lt;section style=&quot;width: 0px; margin-left: 5px; border-right: 10px solid rgb(170, 38, 17); display: inline-block; margin-top: 1.7em; vertical-align: top; border-top: 6px solid transparent !important; border-bottom: 6px solid transparent !important;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; background-color: rgb(170, 38, 17); width: 90%; padding: 8px; margin: 0.5em auto; border-radius: 8px;&quot;&gt;&lt;section style=&quot;color: rgb(255, 255, 255);&quot;&gt;&lt;p style=&quot;clear: none; white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;外交部：委内瑞拉是主权国家，有权自主选择合作伙伴。&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;据路透社报道，一名美国官员当地时间1月22日宣称，美国政府允许中国购买委内瑞拉石油，但不得沿用马杜罗政府时期售卖原油时的“不公平低价倾销”的价格。&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span&gt;在1月23日举行的中国外交部例行记者会上，外交部发言人郭嘉昆在回应路透社记者“中方对此有何评论”的提问时表示，委内瑞拉是主权国家，有权自主选择合作伙伴。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section style=&quot;font-size: 14px; color: rgb(124, 125, 126); line-height: 1.75;&quot;&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;环球时报-环球网报道 记者 乌元春&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;审核 | 卢长银&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;编辑 | 王晓娇&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;strong&gt;&lt;span&gt;校对 | 吴锦&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/section&gt;&lt;section style=&quot;text-align: left; display: flex;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 46%;&quot;&gt;&lt;section style=&quot;margin: 0.5em 0px;&quot;&gt;&lt;section style=&quot;border-top: 1px dotted rgb(18, 39, 54);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 8%;&quot;&gt;&lt;section style=&quot;text-align: center; margin: 8px 0% 10px; line-height: 0;&quot;&gt;&lt;section style=&quot;vertical-align: middle; display: inline-block; line-height: 0;&quot;&gt;&lt;img class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_gif/wlCrBZoK8HGiaQXfQ53X6ia8y5DaRF2XZFGmSgvPQcAZYPHxx6ccMgibJrdt5OzcVwRw8zQqcP6Ed1d6pAiczfzCkQ/640?wx_fmt=gif&amp;amp;from=appmsg&quot; style=&quot;vertical-align: middle; width: 100%;&quot; /&gt;&lt;/section&gt;&lt;/section&gt;&lt;/s