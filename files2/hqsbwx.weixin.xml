<title>英国首相斯塔默宣布辞职</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E8%8B%B1%E5%9B%BD%E9%A6%96%E7%9B%B8%E6%96%AF%E5%A1%94%E9%BB%98%E5%AE%A3%E5%B8%83%E8%BE%9E%E8%81%8C</link>
<content:encoded>&lt;div&gt;&lt;div&gt;&lt;div class=&quot;rich_media_content&quot; id=&quot;js_content&quot;&gt;&lt;section style=&quot;font-style: normal; font-weight: 400; text-align: justify; font-size: 16px; color: rgb(62, 62, 62);&quot;&gt;&lt;section style=&quot;margin: 0px; padding-left: 15px;&quot;&gt;&lt;section style=&quot;display: inline-block; vertical-align: top; width: 100%;&quot;&gt;&lt;section&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;border-left: 1px solid rgb(170, 38, 17); height: 1.2em; border-top-color: rgb(170, 38, 17); border-right-color: rgb(170, 38, 17); border-bottom-color: rgb(170, 38, 17);&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section&gt;&lt;section style=&quot;width: 0px; margin-left: 5px; border-right: 10px solid rgb(170, 38, 17); display: inline-block; margin-top: 1.7em; vertical-align: top; border-top: 6px solid transparent !important; border-bottom: 6px solid transparent !important;&quot;&gt;&lt;svg viewBox=&quot;0 0 1 1&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;/svg&gt;&lt;/section&gt;&lt;section style=&quot;display: inline-block; vertical-align: middle; background-color: rgb(170, 38, 17); width: 90%; padding: 8px; margin: 0.5em auto; border-radius: 8px;&quot;&gt;&lt;section style=&quot;color: rgb(255, 255, 255);&quot;&gt;&lt;p style=&quot;clear: none; white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;当地时间6月22日，英国首相斯塔默宣布辞职。&lt;/span&gt;&lt;/p&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;/section&gt;&lt;p style=&quot;white-space: normal; margin: 0px; padding: 0px;&quot;&gt;&lt;span&gt;&lt;br /&gt;&lt;/span&gt;&lt;/p&gt;&lt;section&gt;&lt;img alt=&quot;图片&quot; class=&quot;rich_pages wxw-img&quot; src=&quot;http://img2.jintiankansha.me/get?src=http://mmbiz.qpic.cn/mmbiz_jpg/sSglytszxLYYao9POsbz