<title>美国发布有关UFO的文件</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E7%BE%8E%E5%9B%BD%E5%8F%91%E5%B8%83%E6%9C%89%E5%85%B3UFO%E7%9A%84%E6%96%87%E4%BB%B6</link>
