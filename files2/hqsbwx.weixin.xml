<title>法国宣布：禁止本-格维尔入境</title>
<link>http://weixin.sogou.com/weixin?type=2&amp;query=%E7%8E%AF%E7%90%83%E6%97%B6%E6%8A%A5+%E6%B3%95%E5%9B%BD%E5%AE%A3%E5%B8%83%EF%BC%9A%E7%A6%81%E6%AD%A2%E6%9C%AC-%E6%A0%BC%E7%BB%B4%E5%B0%94%E5%85%A5%E5%A2%83</link>
